generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())

  packages        ClientPackage[]
  bookings        Booking[]
  trainedSessions Session[]        @relation("TrainerSessions")
  packageRequests PackageRequest[]
  programAccess   ProgramAccess[]
}

model Package {
  id            String      @id @default(cuid())
  name          String
  description   String?
  type          PackageType
  totalSessions Int
  price         Float?

  clientPackages  ClientPackage[]
  packageRequests PackageRequest[]
}

model PackageRequest {
  id        String               @id @default(cuid())
  userId    String
  packageId String
  status    PackageRequestStatus @default(PENDING)
  note      String?
  createdAt DateTime             @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])
}

model ClientPackage {
  id                String    @id @default(cuid())
  userId            String
  packageId         String
  remainingSessions Int
  isActive          Boolean   @default(false)
  activatedAt       DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])
}

model Session {
  id          String      @id @default(cuid())
  type        PackageType
  trainerId   String?
  startTime   DateTime
  maxCapacity Int         @default(15)
  createdAt   DateTime    @default(now())

  trainer  User?     @relation("TrainerSessions", fields: [trainerId], references: [id])
  bookings Booking[]
}

model Booking {
  id               String    @id @default(cuid())
  clientId         String
  sessionId        String
  createdAt        DateTime  @default(now())
  notificationRead Boolean   @default(false)
  cancelledAt      DateTime?
  lateCancellation Boolean   @default(false)

  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([clientId, sessionId])
}

model AdminNotification {
  id        String   @id @default(cuid())
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Online Program ───────────────────────────────────────────────────────────

model Video {
  id          String        @id @default(cuid())
  title       String
  url         String
  category    VideoCategory
  description String?
  createdAt   DateTime      @default(now())

  exercises ProgramExercise[]
}

model Program {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  trainings ProgramTraining[]
  access    ProgramAccess[]
}

model ProgramTraining {
  id        String @id @default(cuid())
  programId String
  order     Int
  title     String

  program  Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  sections ProgramSection[]
}

model ProgramSection {
  id         String @id @default(cuid())
  trainingId String
  order      Int
  title      String

  training  ProgramTraining   @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]
}

model ProgramExercise {
  id        String  @id @default(cuid())
  sectionId String
  videoId   String
  order     Int
  setsReps  String
  note      String?

  section ProgramSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  video   Video          @relation(fields: [videoId], references: [id])
}

model ProgramAccess {
  id        String   @id @default(cuid())
  userId    String
  programId String
  grantedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

enum Role {
  ADMIN
  TRAINER
  CLIENT
}

enum PackageType {
  PERSONAL
  GROUP
}

enum PackageRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoCategory {
  MOBILNOST
  CORE
  NOGE
  LEDJA
  GRUDI
  RAMENA
  BICEPS
  TRICEPS
  KARDIO
  OSTALO
}
